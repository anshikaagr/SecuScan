{
  "id": "sharepoint_scanner",
  "name": "Sharepoint Scanner",
  "version": "1.0.0",
  "description": "Check SharePoint for security issues, misconfigs, and more.",
  "long_description": "Check SharePoint for security issues, misconfigs, and more.",
  "category": "vulnerability",
  "author": {
    "name": "SecuScan Contributors",
    "email": "dev@secuscan.local"
  },
  "license": "MIT",
  "icon": "\ud83d\udee0\ufe0f",
  "engine": {
    "type": "cli",
    "binary": "nuclei"
  },
  "command_template": [
    "nuclei",
    "-u",
    "{target}",
    "-silent"
  ],
  "fields": [
    {
      "id": "target",
      "label": "SharePoint URL",
      "type": "string",
      "required": true,
      "placeholder": "https://sharepoint.secuscan.in",
      "help": "Enter the full SharePoint site URL to scan for security issues, misconfigurations, and exposed resources.",
      "validation": {
        "pattern": "^https?://",
        "message": "Must be a valid HTTP(S) URL"
      }
    }
  ],
  "presets": {
    "default": {}
  },
  "output": {
    "format": "text",
    "parser": "custom"
  },
  "safety": {
    "level": "intrusive",
    "requires_consent": true,
    "consent_message": "SharePoint scanning requires explicit permission.",
    "rate_limit": {
      "max_per_hour": 20,
      "max_concurrent": 1
    }
  },
  "dependencies": {
    "binaries": [
      "nuclei"
    ],
    "python_packages": [],
    "system_packages": []
  },
  "checksum": "6022abd9de7dfe7135915fe02b8c99a6dde615e89c17836ab63123d6572c2219"
}
